# FBO 2 Project API Keys
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to version control

# Prolific
# Only PROLIFIC_API_TOKEN is required for Oussema's account (simple, no
# workspace/project visible in UI). The workspace ID is auto-discovered.
PROLIFIC_API_TOKEN="your-prolific-token-here"
PROLIFIC_WORKSPACE_ID=""
PROLIFIC_PROJECT_ID=""

# Google Apps Script READ_TOKEN (shared secret for the doGet endpoint).
# Must match the READ_TOKEN Script Property set on the Apps Script web app.
# Used by code/02_collect/FETCH_RESPONSES.py to pull sheet data.
FBO2_SHEET_READ_TOKEN="your-read-token-here"

# Dry-run mode (set to true to prevent API calls)
FBO_DRY_RUN=false
